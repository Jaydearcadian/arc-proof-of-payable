{
  "name": "arc-proof-of-payable",
  "version": "0.1.0",
  "description": "Lifecycle-specific verifiable payable proofs for Arc builders.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "public",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "node --test --import tsx test/*.test.ts",
    "start": "node dist/server.js"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
